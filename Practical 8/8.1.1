#include <stdio.h>
#include <stdlib.h>

struct node {
    int vertex;
    struct node *next;
};

typedef struct node *GNODE;

GNODE graph[20] = {NULL};

// Create node
GNODE createNode(int v) {
    GNODE newNode = (GNODE)malloc(sizeof(struct node));
    newNode->vertex = v;
    newNode->next = NULL;
    return newNode;
}

// add at end
void addAtEnd(int src, int dest) {
    GNODE newNode = createNode(dest);

    if (graph[src] == NULL) {
        graph[src] = newNode;
    } else {
        GNODE temp = graph[src];
        while (temp->next != NULL)
            temp = temp->next;
        temp->next = newNode;
    }
}

// print adjacency list
void print(int *N) {
    for (int i = 1; i <= *N; i++) {
        if (graph[i] != NULL) {
            printf("%d=>", i);
            GNODE temp = graph[i];
            while (temp != NULL) {
                printf("%d->", temp->vertex);
                temp = temp->next;
            }
            printf("\n");
        }
    }
}

// insert vertex
void insertVertex(int *N) {
    int newV = ++(*N);

    int k, v;

    // edges to new vertex
    scanf("%d", &k);
    for (int i = 0; i < k; i++) {
        scanf("%d", &v);

        if (v < 1 || v > *N) {
            printf("Invalid vertex.\n");
            (*N)--;
            return;
        }

        addAtEnd(v, newV);
    }

    // edges from new vertex
    scanf("%d", &k);
    for (int i = 0; i < k; i++) {
        scanf("%d", &v);

        if (v < 1 || v > *N) {
            printf("Invalid vertex.\n");
            (*N)--;
            return;
        }

        addAtEnd(newV, v);
    }

    printf("After inserting vertex the adjacency list is :\n");
    print(N);
}

// insert edge
void insertEdge(int *N) {
    int src, dest;

    printf("Enter the source vertex of the edge : ");
    scanf("%d", &src);

    printf("Enter the destination vertex of the edge : ");
    scanf("%d", &dest);

    if (src < 1 || src > *N || dest < 1 || dest > *N) {
        printf("Invalid vertex.\n");
        return;
    }

    addAtEnd(src, dest);

    printf("After inserting edge the adjacency list is :\n");
    print(N);
}

// delete edge
void deleteEdge(int *N) {
    int src, dest;

    printf("Enter the source vertex of the edge : ");
    scanf("%d", &src);

    printf("Enter the destination vertex of the edge : ");
    scanf("%d", &dest);

    if (src < 1 || src > *N || dest < 1 || dest > *N) {
        printf("Invalid vertex.\n");
        return;
    }

    GNODE temp = graph[src], prev = NULL;

    while (temp != NULL) {
        if (temp->vertex == dest) {
            if (prev == NULL)
                graph[src] = temp->next;
            else
                prev->next = temp->next;

            free(temp);
            break;
        }
        prev = temp;
        temp = temp->next;
    }

    printf("After deleting edge the adjacency list is :\n");
    print(N);
}

// delete vertex
void deleteVertex(int *N) {
    if (*N == 0) {
        printf("Graph is empty.\n");
        return;
    }

    int v;
    printf("Enter the vertex to be deleted : ");
    scanf("%d", &v);

    if (v < 1 || v > *N) {
        printf("Invalid vertex.\n");
        return;
    }

    // remove outgoing edges
    GNODE temp = graph[v];
    while (temp) {
        GNODE t = temp;
        temp = temp->next;
        free(t);
    }
    graph[v] = NULL;

    // remove incoming edges
    for (int i = 1; i <= *N; i++) {
        GNODE curr = graph[i], prev = NULL;

        while (curr) {
            if (curr->vertex == v) {
                if (prev == NULL)
                    graph[i] = curr->next;
                else
                    prev->next = curr->next;

                GNODE del = curr;
                curr = curr->next;
                free(del);
            } else {
                prev = curr;
                curr = curr->next;
            }
        }
    }

    printf("After deleting vertex the adjacency list is :\n");
    print(N);
}
